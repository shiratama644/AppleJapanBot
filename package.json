{
  "name": "mochi_bot",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "db:migrate": "tsx src/db/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard": "cd dashboard && pnpm dev",
    "build": "tsc && pnpm run build:dashboard",
    "build:dashboard": "cd dashboard && pnpm install --prefer-offline && pnpm run build && node -e \"const{rmSync,cpSync}=require('fs');rmSync('../dist/dashboard/public',{recursive:true,force:true});cpSync('out','../dist/dashboard/public',{recursive:true})\"",
    "start": "node dist/index.js"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "kysely": "^0.28.14",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
