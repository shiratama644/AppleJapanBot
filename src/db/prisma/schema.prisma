generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LinkedPlayer {
  guildId     String   @map("guild_id")
  discordId   String   @map("discord_id")
  discordName String   @map("discord_name")
  mcid        String
  edition     String
  headUrl     String   @map("head_url")
  linkedAt    DateTime @default(now()) @map("linked_at")

  @@id([guildId, discordId])
  @@map("linked_players")
}

model BotConfig {
  key   String @id
  value String

  @@map("bot_config")
}

model GuildConfig {
  guildId String @map("guild_id")
  key     String
  value   String

  @@id([guildId, key])
  @@map("guild_config")
}
