# Discord Bot Token（Discordデベロッパーポータルで取得）
DISCORD_TOKEN=your_discord_bot_token_here

# コマンドを有効にするサーバー（ギルド）のID
GUILD_ID=your_guild_id_here

# コマンド受付チャンネルID（すべてのコマンドで共通）
CHANNEL_INPUT_ID=your_input_channel_id_here

# 連携リスト表示チャンネルID（デフォルト設定）
CHANNEL_B_ID=your_list_channel_id_here

# テキストコマンドのプレフィックス（デフォルト: /）
# COMMAND_PREFIX=/
