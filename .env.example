# Discord Bot Token（Discordデベロッパーポータルで取得）
DISCORD_TOKEN=your_discord_bot_token_here

# テキストコマンドのプレフィックス（デフォルト: /）
# COMMAND_PREFIX=/

# PostgreSQL接続URL（KyselyのDATABASE_URLとして使用）
# 書式: postgresql://<ユーザー名>:<パスワード>@<ホスト>:<ポート>/<データベース名>
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name

# PostgreSQL SSL接続を有効にするか（本番/クラウドDBでは true、ローカルでは false）
DB_SSL=false


# 以下の4つをすべて設定するとダッシュボードが有効になります

# ダッシュボードのポート番号（デフォルト: 3000）
DASHBOARD_PORT=3000

# セッション署名用のランダム文字列（必須）
SESSION_SECRET=your_random_session_secret_here

# Discord OAuth2 アプリのクライアントID（Discordデベロッパーポータルで取得）
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord OAuth2 アプリのクライアントシークレット
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth2 コールバックURL（Discordデベロッパーポータルの「Redirects」に登録したものと一致させる）
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
